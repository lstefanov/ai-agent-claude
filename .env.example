APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Клиентски портал: задай ДВАТА за поддомейн режим (админ → APP_DOMAIN,
# клиент → CLIENT_DOMAIN). Празни → клиентският портал е на path-префикс /client.
APP_DOMAIN=
CLIENT_DOMAIN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Must exceed the longest job timeout (ExecuteNodeJob::$timeout = 1200s) so long
# site-crawl nodes are not re-dispatched mid-run (MaxAttemptsExceededException).
REDIS_QUEUE_RETRY_AFTER=1800

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis (pure-PHP client) — MAMP PHP 8.2 has no phpredis extension.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PHP binary used for background artisan commands (e.g. models:pull)
PHP_CLI_BINARY=/opt/homebrew/bin/php

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_FALLBACK=llama3.1:8b
# Колко ЛОКАЛНИ нода генерират едновременно (глобален лимит — те делят един GPU).
# 1 при 8–16 GB VRAM. Cloud нодовете (openai/*, anthropic/*) винаги вървят паралелно.
# Реалният паралелизъм е min(брой queue workers, paid нодове + OLLAMA_MAX_CONCURRENT);
# composer dev пуска 3 worker-а за flows опашката.
OLLAMA_MAX_CONCURRENT=1
# Колко дълго моделът стои зареден във VRAM след последна заявка (30m / 1h / -1 = завинаги).
OLLAMA_KEEP_ALIVE=30m

# Памет на flow-а (дедупликация на съдържание между run-ове + поуки per агент).
# FLOW_MEMORY_ENABLED=true
# Embeddings (памет + знания): ollama (по подразбиране, БЕЗПЛАТНО локално;
# изисква `ollama pull bge-m3` на Ollama хоста) | gemini (безплатен tier)
# | openai (платен, центове).
# MEMORY_EMBEDDING_PROVIDER=ollama
# MEMORY_EMBEDDING_MODEL=
# OLLAMA_EMBEDDING_MODEL=bge-m3
# Cosine праг "твърде подобно" (≈ правилото „до 30-40% припокриване“).
# MEMORY_SIMILARITY_THRESHOLD=0.80
# MEMORY_DEDUP_MAX_RETRIES=2

# Inline step-QA съдия (StepQaGate). Празно → локален qwen3:4b (шумен на дълги
# research изходи). Силен евтин съдия: gemini/gemini-3.1-flash-lite. Cost cap
# спира скъпите преигравания на един възел (0 = изключено).
# QA_VERIFIER_MODEL=gemini/gemini-3.1-flash-lite
# QA_MAX_RETRY_COST_USD=0.50

# Planner LLM („агентът, който създава агенти"):
# openai | anthropic (cloud, най-добро качество) | deepseek (почти безплатно)
# | gemini (БЕЗПЛАТЕН tier ~1500 заявки/ден) | ollama (БЕЗПЛАТНО, локално)
GENERATOR_PROVIDER=openai
# qwen3:14b на 16 GB VRAM; qwen3:8b на 8 GB (14b прелива към CPU и планира бавно)
OLLAMA_PLANNER_MODEL=qwen3:14b
# Контекст на локалния planner (design промптът лесно надхвърля 8K токена)
OLLAMA_PLANNER_NUM_CTX=16384
# Thinking на локалния planner: празно = авто (изключва се за qwen3/deepseek-r1)
OLLAMA_PLANNER_THINK=

# ХИБРИДНО ПЛАНИРАНЕ (опционално): различен provider/model за всяка фаза.
# Непопълнено → GENERATOR_PROVIDER. Препоръчан хибрид: скъп модел САМО за
# дизайна, безплатен/евтин за останалите фази:
#   PLANNER_DESIGN_PROVIDER=anthropic   (Claude проектира агентите + връзките)
#   PLANNER_INTENT_PROVIDER=gemini      (или deepseek/openai — евтини фази)
#   PLANNER_CRITIQUE_PROVIDER=gemini
#   PLANNER_REVISION_PROVIDER=openai
# PLANNER_*_MODEL override-ва default модела на съответния провайдър.
PLANNER_INTENT_PROVIDER=
PLANNER_INTENT_MODEL=
PLANNER_DESIGN_PROVIDER=
PLANNER_DESIGN_MODEL=
PLANNER_CRITIQUE_PROVIDER=
PLANNER_CRITIQUE_MODEL=
PLANNER_REVISION_PROVIDER=
PLANNER_REVISION_MODEL=

# Eval Suite LLM-as-judge — евтин/бърз по подразбиране (изисква GEMINI_API_KEY);
# смени на openai/anthropic за по-строг judge.
EVAL_JUDGE_PROVIDER=gemini
EVAL_JUDGE_MODEL=gemini-3.1-flash-lite
# Колко eval FlowRun-а текат едновременно (локалният GPU е 1 слот — повече = timeout-и).
EVAL_MAX_CONCURRENT=3

# Anthropic (Claude) — planner (ако GENERATOR_PROVIDER=anthropic) + runtime ☁ агенти + A/B + ескалация
ANTHROPIC_API_KEY=
ANTHROPIC_GENERATOR_MODEL=claude-sonnet-4-6

# OpenAI (ChatGPT) — planner (ако GENERATOR_PROVIDER=openai) + runtime ☁ агенти + embeddings + A/B
# ВНИМАНИЕ: OPENAI_BASE_URL (ако се override-ва) вече ВКЛЮЧВА версията: https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_GENERATOR_MODEL=gpt-4o

# DeepSeek V4 — планер + runtime ("deepseek/<model>" възли), почти безплатен
# (~$0.01/генерация с V4-Pro). deepseek-v4-pro = най-силният (дизайн фазата);
# deepseek-v4-flash = бърз/евтин за леки фази и runtime стъпки.
# СТАРИТЕ имена deepseek-chat/deepseek-reasoner спират на 2026-07-24.
DEEPSEEK_API_KEY=
DEEPSEEK_GENERATOR_MODEL=deepseek-v4-pro
DEEPSEEK_RUNTIME_MODEL=deepseek-v4-flash

# Google Gemini — planner-only през OpenAI-съвместимия endpoint; free tier ~1500 заявки/ден.
# Ако схема бъде отхвърлена от compat слоя: GEMINI_STRUCTURED_OUTPUT=json_object
GEMINI_API_KEY=
# flash-lite = най-голям безплатен капацитет, без thinking преамбюл.
# Алтернативи: gemini-3.5-flash (free, по-силен, но thinking хаби бюджета),
# gemini-3-flash-preview (free), gemini-3.1-pro-preview (САМО платен tier,
# $2/$12 на 1M — изисква включен billing; максимално качество за дизайна).
GEMINI_GENERATOR_MODEL=gemini-3.1-flash-lite
GEMINI_STRUCTURED_OUTPUT=json_schema

# xAI Grok — планер + runtime ("xai/<model>" възли). grok-4.3 = флагман и
# същевременно най-бързият модел ($1.25/$2.50 на 1M, 1M контекст). Кредити: $25
# при регистрация + до $150/мес. през data-sharing програмата (console.x.ai).
XAI_API_KEY=
XAI_GENERATOR_MODEL=grok-4.3
XAI_RUNTIME_MODEL=grok-4.3

# Alibaba Qwen (Model Studio international) — планер + runtime ("qwen/<model>").
# Изрична поддръжка на 119 езика вкл. БЪЛГАРСКИ. Free tier 1M+1M токена за нови
# акаунти (modelstudio.console.alibabacloud.com, ключ от Singapore региона).
# qwen3.7-plus $0.40/$1.60 (multimodal, 1M ctx); qwen3.6-flash $0.25/$1.50;
# qwen3.7-max $2.50/$7.50 (text-only reasoning флагман); qwen3.5-flash $0.10/$0.40 (cheapest)
QWEN_API_KEY=
QWEN_GENERATOR_MODEL=qwen3.7-plus
QWEN_RUNTIME_MODEL=qwen3.6-flash

# Perplexity Search API — premium web search + people search tools (not a chat provider)
PERPLEXITY_API_KEY=
PERPLEXITY_SEARCH_URL=https://api.perplexity.ai/search
PERPLEXITY_SEARCH_MAX_RESULTS=10
PERPLEXITY_SEARCH_COUNTRY=BG
PERPLEXITY_REQUEST_COST_USD=0.005

# Brave Search API (https://brave.com/search/api/) — default web_search backend
BRAVE_SEARCH_API_KEY=
BRAVE_RESULTS_COUNT=10
# Цена за Brave заявка ($/заявка) за одита в /admin/costs (free план = 0; платен ~$5/1000).
BRAVE_REQUEST_COST_USD=0.005

# Web search провайдър за инструмента `web_search`: brave | perplexity (default brave).
WEB_SEARCH_PROVIDER=brave

# Mistral OCR — document/image extraction tool (not a chat provider)
MISTRAL_API_KEY=
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_TIMEOUT=120
MISTRAL_OCR_PAGE_COST_USD=0.002

# AI-assist бутони ("Подобри с AI" / "Генерирай с AI") — независим от GENERATOR_PROVIDER
# Провайдъри: ollama | openai | anthropic | deepseek | gemini | xai | qwen
ASSIST_PROVIDER=ollama
# ollama (БЕЗПЛАТНО, локално; bggpt е тунинг за български)
ASSIST_OLLAMA_MODEL=todorov/bggpt:Gemma-3-12B-IT-Q5_K_M
# openai (ако ASSIST_PROVIDER=openai)
ASSIST_OPENAI_MODEL=gpt-4o-mini
# anthropic (ако ASSIST_PROVIDER=anthropic)
ASSIST_ANTHROPIC_MODEL=claude-haiku-4-5
# deepseek (ако ASSIST_PROVIDER=deepseek; почти безплатно)
ASSIST_DEEPSEEK_MODEL=deepseek-v4-flash
# gemini (ако ASSIST_PROVIDER=gemini; безплатен tier)
ASSIST_GEMINI_MODEL=gemini-3.1-flash-lite
# xai (ако ASSIST_PROVIDER=xai; grok-4.3 е флагман + най-бърз)
ASSIST_XAI_MODEL=grok-4.3
# qwen (ако ASSIST_PROVIDER=qwen; явна поддръжка на BG, 1M+1M free tier)
ASSIST_QWEN_MODEL=qwen3.5-flash

# Builder Copilot — чат асистентът в builder-а (изисква cloud провайдър с tool
# calling: openai | anthropic | deepseek | gemini | xai | qwen — НЕ ollama).
# Непопълнено → GENERATOR_PROVIDER (ако е cloud) с неговия generator модел.
BUILDER_ASSISTANT_PROVIDER=
BUILDER_ASSISTANT_MODEL=

# Разговорният създател в клиентския портал (изцяло AI). Празно → fallback към
# BUILDER_ASSISTANT, после planner-а, после openai. gpt-4o = качество; mini = евтино.
CLIENT_WIZARD_PROVIDER=openai
CLIENT_WIZARD_MODEL=gpt-4o

CRAWL_SERVICE_URL=http://localhost:8189
CRAWL_SERVICE_ENABLED=true
CRAWL_SERVICE_TIMEOUT=15
# Таван страници за crawl_site tool-а на агентите (BFS).
CRAWL_MAX_PAGES=30

# База знания v2 (ресурси: url / файл / снимка / бележка).
# Embeddings: ollama (default, bge-m3) | gemini (free tier) | openai (платен).
# KNOWLEDGE_EMBEDDING_PROVIDER=ollama
# KNOWLEDGE_EMBEDDING_MODEL=bge-m3
# Синтез на digest-и + извличане на факти (най-тежката ingest LLM работа):
# gemini (free tier, default) | deepseek | openai | xai | qwen.
# KNOWLEDGE_SYNTH_PROVIDER=gemini
# KNOWLEDGE_SYNTH_MODEL=
# Чат "Тествай знанията": ollama (default, BgGPT през ModelSelector) | cloud.
# KNOWLEDGE_CHAT_PROVIDER=ollama
# KNOWLEDGE_CHAT_MODEL=
# Таван уникални страници при BFS обхождане на url ресурс.
# KNOWLEDGE_SITE_MAX_PAGES=200
# Факт-дедуп: cosine праг за supersede на стар факт + мин. confidence.
# KNOWLEDGE_FACT_SIMILARITY=0.86
# KNOWLEDGE_FACT_MIN_CONFIDENCE=0.5

# Google Places API (New) — за Google ревюта/оценки (Places API New в Google Cloud)
GOOGLE_PLACES_API_KEY=

ADMIN_PASSWORD=changeme

# ── MCP Конектори ────────────────────────────────────────────────────────────
# Google OAuth (Gmail/Sheets/Drive конектори, глобален FlowAI app през Socialite).
# Активирай Gmail/Sheets/Drive API; redirect URI = .../oauth/google/callback
# ВАЖНО: Google не приема flowai.local — ползвай localhost или публичен https (ngrok).
# Google OAuth (MCP конектори: Gmail/Sheets/Drive/Docs/Calendar) — глобален FlowAI Google app.
# Един callback обслужва и админ, и клиентския портал (stateless state с origin).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# --- AI Организация (org layer) ---
# ORG_MANAGER_LEVEL / ORG_DIRECTOR_LEVEL → виж секцията „КРЕДИТИ / БИЛИНГ" по-долу (те таксуват).
ORG_PERSONA_PORTRAITS=true
ORG_ACT_ENABLED=false
ORG_INTERVIEW_MAX_QUESTIONS=8
# Дълбокото проучване и интервюто в онбординга са first-impression фази.
# По default са на gpt-4o-mini; основният Flow planner може да остане локален.
ORG_RESEARCH_PROVIDER=openai
ORG_RESEARCH_MODEL=gpt-4o-mini
ORG_INTERVIEW_PROVIDER=openai
ORG_INTERVIEW_MODEL=gpt-4o-mini
# LLM, който създава отделите/директорите/асистентите (фази org_compose+org_design).
# Празно → пада към GENERATOR_PROVIDER. Сменяем: openai|anthropic|deepseek|gemini|xai|qwen.
ORG_DESIGN_PROVIDER=openai
ORG_DESIGN_MODEL=gpt-4o-mini
# Директорски „tick" (периодичен преглед на отдела + предложения). Леко структурирано
# разсъждение в български — не се нуждае от ultra. Празно → GENERATOR_PROVIDER (локален Ollama).
# За по-добра ефективност локално: ORG_DIRECTOR_TICK_MODEL=qwen3:8b (по-бърз от qwen3:14b).
# Евтин cloud (секунди вместо минути, изисква API ключ): gemini-3.1-flash-lite или gpt-4o-mini.
ORG_DIRECTOR_TICK_PROVIDER=ollama
ORG_DIRECTOR_TICK_MODEL=qwen3:14b
# Управителски преглед (OrgReviewService) — структурни предложения (hire/fire/mandate/task).
# Същият съвет като director_tick. Празно → GENERATOR_PROVIDER (локален Ollama).
ORG_REVIEW_PROVIDER=
ORG_REVIEW_MODEL=
# Чат с член (MemberChatService) — диалог с асистент/директор + предложения в Кутията.
# Съветът за български е същият. Празно → GENERATOR_PROVIDER (локален Ollama).
MEMBER_CHAT_PROVIDER=
MEMBER_CHAT_MODEL=
# Колко асистента на отдел (всеки отдел е достатъчно сложен → поне 2).
ORG_MIN_ASSISTANTS_PER_DIRECTOR=2
ORG_MAX_ASSISTANTS_PER_DIRECTOR=4
# Портретни аватари на org членове (ComfyUI). По подразбиране ползва COMFYUI_CHECKPOINT.
# За по-добри headshot-и инсталирай photorealistic XL модел в ComfyUI и задай, напр.:
# COMFYUI_PORTRAIT_CHECKPOINT=juggernautXL_v9.safetensors
# COMFYUI_PORTRAIT_CHECKPOINT=
# COMFYUI_PORTRAIT_NEGATIVE=
# COMFYUI_PORTRAIT_MAX_ATTEMPTS=4
# ═══════════════════════════════════════════════════════════════════════════════════
# КРЕДИТИ / БИЛИНГ — всичко, което таксува кредити на фирмите (на едно място)
# ───────────────────────────────────────────────────────────────────────────────────
# Кредитен модел за едно LLM действие:
#   кредити = STAR[ниво] × ceil(изходни_токени / BILLING_TOKEN_DIVISOR) × BILLING_WORK_PER_KTOKEN
# Не-LLM инструменти (търсене / OCR / портрет) се таксуват ПЛОСКО (BILLING_FLAT_*).
# Преди старт се РЕЗЕРВИРА консервативна оценка (STAR × BILLING_EST_*); след работата
# settle реконсилира срещу реално изхарчените токени и връща неизползвания остатък.
# ВАЖНО: реалният USD разход (за теб) ≠ кредитите. Кредитите са това, което таксуваш на
# ФИРМАТА; затова безплатен локален модел = $0 за теб, но >0 кредити за фирмата.
# ═══════════════════════════════════════════════════════════════════════════════════

# ── Глобални множители и константи ──
# Надценка USD→кредити за инструменти с явна $ цена (и fallback за непознат flat инструмент).
BILLING_CREDIT_MARKUP=3.0
# Глобален множител върху ВСИЧКИ LLM кредити. 1.0 = без ефект; 2.0 = двойно по-скъпо навсякъде.
BILLING_WORK_PER_KTOKEN=1.0
# Позволи балансът да падне под 0 (овърдрафт), ако фирмата има активен абонамент.
BILLING_OVERAGE=true
# На колко изходни токена = 1 "единица" работа (1000 = таксуване на всеки 1k токена).
BILLING_TOKEN_DIVISOR=1000
# Минимум кредити, които се резервират за операция (под това не слиза).
BILLING_MIN_RESERVE_CREDITS=1
# Минимална оценка за резервация (за да не резервираме 0 за платена операция).
BILLING_MIN_ESTIMATE_CREDITS=1
# Етикет на текущата тарифа — записва се при всяка операция (credit_reservations.billing_meta),
# за да е обяснима по-късно дори след промяна на тарифите тук.
BILLING_PRICING_VERSION=2026-06

# ── Базови множители по ниво модел (ModelLevel) ──
# Колко кредити струва 1 единица работа (1k изходни токена) на дадено ниво. По-високо ниво =
# по-умен/скъп модел = повече кредити. Нивото на агента идва от model-cost level-а на flow-а.
BILLING_STAR_LOW=1       # low — предимно локални/евтини модели
BILLING_STAR_MEDIUM=3    # medium (по подразбиране) — евтини облачни (Gemini/DeepSeek/xAI/Qwen)
BILLING_STAR_HIGH=6      # high — облачни + малко OpenAI
BILLING_STAR_ULTRA=12    # ultra — всичко OpenAI + малко Anthropic
BILLING_STAR_GOD=25      # god — флагмани (gpt-4o / claude-sonnet)

# ── Плоски кредити за не-LLM инструменти (таксуват се на бройка, не по токени) ──
BILLING_FLAT_BRAVE=1       # 1 кредит за всяко Brave уеб търсене (инструмент web_search)
BILLING_FLAT_PLACES=1      # 1 кредит за справка в Google Places (ревюта/локации)
BILLING_FLAT_PERPLEXITY=1  # 1 кредит за всяко Perplexity търсене
BILLING_FLAT_OCR_PAGE=1    # 1 кредит на страница при OCR на документ (Mistral)
BILLING_FLAT_AVATAR=5      # 5 кредита за един генериран портрет (ComfyUI)
BILLING_FLAT_EMBEDDING=0   # 0 — локален bge-m3 е безплатен (ключът е само за пълнота)
# Реалната ТИ цена ($) за един портрет. 0 = локален ComfyUI (безплатно). Сложи >0 ако ползваш
# платен GPU/услуга — влиза в reconciliation като твой реален разход (не като кредити).
COMFYUI_AVATAR_COST_USD=0

# ── Оценки за резервация (хиляди ИЗХОДНИ токена ПРЕДИ старт, по услуга) ──
# Колко се РЕЗЕРВИРА предварително (консервативно). settle връща остатъка след работата.
# По-висока оценка = повече държани кредити докато тече операцията (връщат се), но по-сигурно.
BILLING_EST_TASK_RUN=10         # пускане на дневна задача (цял flow на асистент)
BILLING_EST_GENERATION=12       # планерът проектира flow/агенти от описание
BILLING_EST_ORG_PLANNING=15     # създаване/планиране/разширяване на екип (управител/директори)
BILLING_EST_INTERVIEW=3         # онбординг интервю
BILLING_EST_RESEARCH=8          # AI проучване на бизнеса при онбординг
BILLING_EST_MEMBER_CHAT=2       # един чат ход с член на екипа
BILLING_EST_DIRECTOR_TICK=6     # едно автономно "мислене" на директор
BILLING_EST_ORG_DIGEST=4        # периодично обобщение на организацията
BILLING_EST_TEXT_ASSIST=1       # "Подобри/Генерирай с AI" за едно поле (Тон/Опит/Био/описание)
BILLING_EST_AVATAR=1            # генериране на портрет (реалната цена е плоска — BILLING_FLAT_AVATAR)
BILLING_EST_ASSISTANT=3         # един ход на Builder Copilot (AI помощник в билдъра)
BILLING_EST_CLIENT_WIZARD=3     # един ход на разговорния създател за клиенти
BILLING_EST_KNOWLEDGE_CHAT=2    # един въпрос към базата знания
BILLING_EST_KNOWLEDGE_INGEST=8  # вкарване на URL в базата знания (краулене + синтез)

# ── Ниво на таксуване по услуга (когато операцията няма явно подадено ниво) ──
# Определя кой STAR множител се ползва. org контекстите (планиране/интервю/проучване/digest/
# director tick) наследяват ORG_MANAGER_LEVEL и НЕ се изброяват тук.
BILLING_LEVEL_TEXT_ASSIST=medium      # "Подобри с AI"
BILLING_LEVEL_AVATAR=medium           # портрети
BILLING_LEVEL_ASSISTANT=medium        # Builder Copilot
BILLING_LEVEL_CLIENT_WIZARD=medium    # разговорен създател
BILLING_LEVEL_KNOWLEDGE_CHAT=medium   # чат със знанията
BILLING_LEVEL_KNOWLEDGE_INGEST=medium # вкарване на знания

# ── Hard-gate политика: блокира ли операцията при липса на кредити? ──
# hard = спира/връща грешка при 0 кредити (плащащи и автономни действия).
# soft = best-effort: продължава, но записва разхода като "нетаксуван" (owner инструменти) —
#        за да не блокираме собствените ти инструменти при празен портфейл.
BILLING_GATE_AUTONOMOUS=hard          # всяко автономно действие (иначе заобикаля дневния таван)
BILLING_GATE_TASK_RUN=hard            # пускане на дневна задача
BILLING_GATE_GENERATION_MANUAL=soft   # ръчна генерация на flow в билдъра
BILLING_GATE_GENERATION_ORG=hard      # org генерация (за задача на асистент)
BILLING_GATE_TEXT_ASSIST=soft         # "Подобри с AI"
BILLING_GATE_AVATAR=soft              # портрети
BILLING_GATE_COPILOT=soft             # Builder Copilot (ключът е COPILOT; услугата вътре е "assistant")
BILLING_GATE_CLIENT_WIZARD=soft       # разговорен създател
BILLING_GATE_RESEARCH=soft            # проучване при онбординг
BILLING_GATE_INTERVIEW=soft           # интервю при онбординг
BILLING_GATE_KNOWLEDGE_CHAT=soft      # чат със знанията
BILLING_GATE_KNOWLEDGE_INGEST=soft    # вкарване на знания

# ── Месечни кредити по абонаментен план (PlanSeeder при migrate:fresh --seed) ──
BILLING_PLAN_FREE_MONTHLY=100          # Безплатен
BILLING_PLAN_STARTER_MONTHLY=1000       # Starter
BILLING_PLAN_PRO_MONTHLY=5000           # Professional
BILLING_PLAN_BUSINESS_MONTHLY=20000     # Business
BILLING_PLAN_ENTERPRISE_MONTHLY=100000  # Enterprise

# ── AI Организация — билинг лостове (нива на таксуване + автономни тавани) ──
# Ниво на управителя/директорите → таксува org планиране/интервю/проучване/digest.
ORG_MANAGER_LEVEL=ultra
# Ниво по подразбиране за нов директор.
ORG_DIRECTOR_LEVEL=high
# Стартови кредити, дадени на фирмата при одобряване на екипа (ignition).
ORG_IGNITION_STARTUP_CREDITS=1000
# Дневен таван (абсолютни кредити) за АВТОНОМНИ действия; 0 = без таван.
ORG_AUTON_DAILY_CREDITS=0
# Дневен таван като % от баланса за автономни действия; 0 = без таван.
ORG_AUTON_DAILY_PCT=0
# Запалването (първи tick веднага след одобрение) е освободено от дневния таван.
ORG_AUTON_IGNITION_EXEMPT=true

# ── Плащания (Stripe) — по-късна фаза; сега зареждането е админ-симулирано ──
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
